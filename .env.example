# Database TiDB / MySQL
DB_HOST=
DB_PORT=4000
DB_USER=
DB_PASSWORD=
DB_NAME=

# Flask
SECRET_KEY=
POS_TAX_RATE=0.10
MAX_UPLOAD_SIZE=5242880
SESSION_COOKIE_SECURE=true

# Run database create_all/role seeding once if the database is empty.
# Change back to false after the first successful deployment.
AUTO_INIT_DB=false

# Cloudinary (menu images and staff leave documents)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Resend
RESEND_API_KEY=
RESEND_FROM=Argotelo <no-reply@your-verified-domain.com>
# Optional. When empty on Vercel, the application uses the Vercel URL.
APP_BASE_URL=

# Midtrans
MIDTRANS_SERVER_KEY=
MIDTRANS_CLIENT_KEY=
MIDTRANS_IS_PRODUCTION=false
